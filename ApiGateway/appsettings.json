{
  "ReverseProxy": {
    "Routes": {
      "bookingRoute": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/booking/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/booking"
          }
        ]
      },

      "analyticsRoute": {
        "ClusterId": "analyticsCluster",
        "Match": {
          "Path": "/analytics/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/analytics"
          }
        ]
      }
    },

    "Clusters": {
      "bookingCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5193/"
          }
        }
      },

      "analyticsCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000/"
          }
        }
      }
    }
  }
}